<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
<body>
  <%- include('./partials/nav.ejs') %>

  <main class="main">
    <div class="container">
      <section class="about content">
        <h1 class="h1">About Macro Blog</h1>
        <p class="text-muted mt-4">Macro Blog is a simple, minimal blogging platform built with Node.js, Express, EJS, and MongoDB. It's intended for learning and quick prototyping — clean, responsive, and easy to extend.</p>

        <div class="mt-6">
          <h2 class="h2">Our goals</h2>
          <ul class="mt-3 text-muted">
            <li>Keep the design minimal and readable</li>
            <li>Provide a smooth writing experience</li>
            <li>Be easy to extend with features like authentication, comments, and tagging</li>
          </ul>
        </div>

        <div class="mt-6">
          <h2 class="h2">Get started</h2>
          <p class="text-muted mt-2">Create your first post and see it appear on the home page.</p>
          <a href="/blogs/create" class="btn btn--primary mt-4">Create a Post</a>
        </div>
      </section>
    </div>
  </main>

  <%- include('./partials/footer.ejs') %>
</body>
</html>
