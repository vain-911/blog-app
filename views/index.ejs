<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
<body>

    <%- include('./partials/nav.ejs') %>
    <main class="main">
        <div class="container">
            <section class="blog-list">
                <% if(blogs.length ){ %>
                    <% blogs.forEach(blog => { %>
                        <a class="single" href="/blogs/<%= blog.id %>" >
                        <article class="blog-card">
                            <h3 class="blog-card__title"><%= blog.title %></h3>
                            <p class="blog-card__snippet"><%= blog.snippet %></p>
                        </article>
                        </a>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <h2 class="empty-state__title">No Blogs Found</h2>
                        <p class="empty-state__message">There are no blog posts yet. Start writing today!</p>
                        <a href="/blogs/create" class="btn btn--primary">Create First Post</a>
                    </div>
                <% } %>
            </section>
        </div>
    </main>
    <%- include('./partials/footer.ejs') %>

</body>
</html>