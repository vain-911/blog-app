<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>
  <body>
    <%- include('./partials/nav.ejs') %>

    <main class="main">
      <div class="container">
        <article class="blog-detail">
          <a href="/blogs" class="blog-detail__back">All posts</a>

          <h1 class="blog-detail__title"><%= blog.title %></h1>
          <p class="blog-detail__snippet"><%= blog.snippet %></p>

          <hr class="blog-detail__divider">

          <div class="blog-detail__content"><%- blog.content %></div>

          <div class="blog-detail__actions">
            <a href="/blogs" class="btn btn--secondary">Back to Posts</a>
            <a href="/blogs/edit/<%= blog.id %>" class="btn btn--primary">Update Post</a>
            <a class="btn btn--danger delete" data-doc="<%= blog.id %>">Delete Post</a>
          </div>
        </article>
      </div>
    </main>

    <%- include('./partials/footer.ejs') %>

    <script>
    const deleteButton = document.querySelector('a.delete');
    const id = deleteButton.dataset.doc;
    const endpoint = `/blogs/${id}`;

    deleteButton.addEventListener('click', (e)=>{
      fetch(endpoint, {method:'DELETE'}).then(response=>{
       return response.json();
      }).then((data)=>{
        window.location.href=data.redirect;
      }).catch(err=>{
        console.log(err);
      });
    })

    </script>
  </body>
</html>
