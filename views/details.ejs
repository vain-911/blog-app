<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>
  <body>
    <%- include('./partials/nav.ejs') %>

    <main class="main">
      <div class="container">
        <article class="blog-card">
          <p class="mb-4"><a href="/blogs" class="text-muted">&larr; Back to home</a></p>

          <h1 class="mb-3"><%= blog.title %></h1>
          <p class="text-muted mb-4"><%= blog.snippet %></p>

          <div class="content mb-6"><%- blog.content %></div>

          <div class="gap-4 flex">
            <a class="btn btn--secondary delete" data-doc="<%= blog.id %>">Delete</a>
          </div>
        </article>
      </div>
    </main>

    <%- include('./partials/footer.ejs') %>

    <script>
    const deleteButton = document.querySelector('a.delete');
    const id = deleteButton.dataset.doc;
    const endpoint = `/blogs/${id}`;

    deleteButton.addEventListener('click', (e)=>{
      fetch(endpoint, {method:'DELETE'}).then(response=>{
       return response.json();
      }).then((data)=>{
        window.location.href=data.redirect;
      }).catch(err=>{
        console.log(err);
      });
    })

    </script>
  </body>
</html>
